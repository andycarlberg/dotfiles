# Entry point for environment variables across all POSIX shells
# (Bash, Zsh, Sh)

# Ensure PATH is bootstrapped correctly
. ~/.shell/env_functions
. ~/.shell/common_paths

# Shared env vars (editor, pager, locale) — also sourced by fish via posix_source
. ~/.shell/env_vars

# Enable Homebrew environment
if [ -f "/opt/homebrew/bin/brew" ]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
elif [ -f "/usr/local/bin/brew" ]; then
    eval "$(/usr/local/bin/brew shellenv)"
elif [ -f "/home/linuxbrew/.linuxbrew/bin/brew" ]; then
    eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
elif [ -f "$HOME/.linuxbrew/bin/brew" ]; then
    eval "$($HOME/.linuxbrew/bin/brew shellenv)"
fi

# Legacy env/bash_env support
export ENV=~/.sh/interactive
export BASH_ENV=~/.bash/env

# Activate mise (managed tool versions).
if command -v mise >/dev/null 2>&1; then
    if [ -n "$BASH_VERSION" ]; then
        eval "$(mise activate bash)"
    elif [ -n "$ZSH_VERSION" ]; then
        eval "$(mise activate zsh)"
    fi
fi

# Allow local machine-specific overrides
ssource ~/.shell/env_local
