# Usage: create_alias <alias_name> <command...>
create_alias() {
  NEW_ALIAS="${1}"
  shift
  alias "${NEW_ALIAS}"="$*"
  echo "alias ${NEW_ALIAS}=\"$*\"" >> "$HOME/.shell/interactive_aliases_local"
}

# Open yazi and cd to the directory on exit
y() {
  local tmp
  tmp=$(mktemp -t "yazi-cwd.XXXXX")
  yazi "$@" --cwd-file="$tmp"
  if IFS= read -r cwd < "$tmp" && [ -n "$cwd" ] && [ "$cwd" != "$PWD" ]; then
    cd -- "$cwd"
  fi
  rm -f -- "$tmp"
}

