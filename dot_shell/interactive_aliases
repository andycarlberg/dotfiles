alias gs="git status"
alias ga="git add"
alias gc="git commit -v"
alias gd="git diff"
alias gpsu="git push --set-upstream origin HEAD"
alias gcob="git checkout -b"
alias gp="git push"
alias gpf="git push --force-with-lease"
alias gsw="git switch"
alias gswc="git switch -c"
alias gcan!="git commit -a -v --no-edit --amend"

[ -f "$HOME/.shell/interactive_aliases_local" ] && . "$HOME/.shell/interactive_aliases_local"
