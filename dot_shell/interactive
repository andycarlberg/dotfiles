# Source shared aliases and functions
. ~/.shell/interactive_aliases
. ~/.shell/interactive_functions

# Basic interactive settings
if [ -t 0 ]; then
    # Prevent other users from messaging by default
    mesg n 2>/dev/null
fi

# Activate thefuck (if installed)
if command -v fuck >/dev/null 2>&1; then
    eval "$(thefuck --alias)"
fi
