# Ensure environment is loaded (important for macOS or non-login shells)
[[ -f ~/.shell/env ]] && . ~/.shell/env

# Add local completions directory to fpath before compinit runs.
# Drop generated completion files (e.g. from `mise completions zsh`) into ~/.zsh/completions/.
fpath=(~/.zsh/completions $fpath)

# Configure history
HISTFILE=~/.zsh_history
HISTSIZE=10000
SAVEHIST=10000
setopt SHARE_HISTORY

. ~/.shell/interactive

# Completions
autoload -Uz compinit && compinit

# Prompt
command -v starship >/dev/null 2>&1 && eval "$(starship init zsh)"

# Setup fzf
command -v fzf >/dev/null 2>&1 && source <(fzf --zsh)
