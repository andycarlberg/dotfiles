#!/bin/bash

# Define the expected brew binary path based on OS and architecture
if [[ "$OSTYPE" == "darwin"* ]]; then
    if [[ "$(uname -m)" == "arm64" ]]; then
        BREW_BIN="/opt/homebrew/bin/brew"
    else
        BREW_BIN="/usr/local/bin/brew"
    fi
else
    # Linux (both /home/linuxbrew and ~/.linuxbrew)
    BREW_BIN="/home/linuxbrew/.linuxbrew/bin/brew"
    [[ ! -f "$BREW_BIN" ]] && BREW_BIN="$HOME/.linuxbrew/bin/brew"
fi

# Install Homebrew if it isn't already there
if ! command -v brew &> /dev/null && [[ ! -f "$BREW_BIN" ]]; then
    echo "Installing Homebrew..."
    NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi

# Bootstrap the current script's environment
if [[ -f "$BREW_BIN" ]]; then
    eval "$($BREW_BIN shellenv)"
fi
