[user]
	email = {{ .email | quote }}
	name = {{ .name | quote }}
[init]
	defaultBranch = main
[pull]
	rebase = true
[core]
	pager = delta
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	side-by-side = true
	line-numbers = true
[merge]
	conflictstyle = diff3
[diff]
	colorMoved = default
