#!/bin/bash
# fish_plugins hash: {{ include "dot_config/fish/fish_plugins" | sha256sum }}
set -euo pipefail

FISH=$(command -v fish 2>/dev/null || true)
if [[ -z "$FISH" ]]; then
    echo "fish not found — skipping fisher install" >&2
    exit 0
fi

FISHER_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/fish/fisher"

if [[ ! -d "$FISHER_DIR" ]] || ! "$FISH" -c 'functions -q fisher' 2>/dev/null; then
    echo "Installing fisher..."
    "$FISH" -c 'curl -sL https://raw.githubusercontent.com/jorgebucaran/fisher/main/functions/fisher.fish | source && fisher install jorgebucaran/fisher'
fi

echo "Syncing fisher plugins..."
"$FISH" -c 'fisher update'
